# Normalize line endings to LF in the repo; let Git manage working-tree CRLF on Windows
* text=auto

# Python files always LF
*.py text eol=lf

# Shell scripts always LF
*.sh text eol=lf

# Config / data files always LF
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.json text eol=lf

# Binary files
*.sqlite binary
*.db binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff2 binary
*.ttf binary
*.gz binary
*.zip binary
*.tar binary
*.pyc binary
*.so binary
