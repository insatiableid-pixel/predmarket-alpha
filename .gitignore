# Environment secrets — NEVER commit real credentials
.env

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
.tox/
.tmp/

# Data files (databases, logs, audit trails contain runtime state)
data/*.sqlite
data/*.log
data/*.jsonl
data/kalshi_live/
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Test temp data
tests/tmp_data/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Agent / tool temp files
.hermes/
.hermes-tmp.*
.agents/
.subagent-*.md
skills-lock.json
pi-session-*.html
Droid Readiness Fixes.*

# Misc
*.Zone.Identifier
*:Zone.Identifier
=*

# Generated Codex/Kalshi research artifacts. Existing tracked snapshots remain
# tracked; these rules keep newly generated runtime output directories out of
# future hygiene commits.
docs/codex/macro/*-latest/
docs/codex/macro/latest-*
docs/codex/artifacts/*-latest/
docs/codex/macro/kalshi-sports-evidence-cycle.*

# Local research/reference drops; keep curated docs explicit when needed
*.pdf
*_2026-*.md
!REMEDIATION_2026-06-10_COMPLETE.md
!REMEDIATION_2026-06-10_step1_git_init.md
!AUDIT_hermes_deepseek_v4_2026-06-10.md
