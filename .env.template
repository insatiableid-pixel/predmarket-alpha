# ==============================================================================
# Environment Configuration Template for Kalshi Action Alpha
# Copy this file to '.env' and populate with valid credentials before launch.
# ==============================================================================

# 1. Global Platform Controls
# ----------------------------
# Set to 'true' to resume operations if the platform triggers the 20% drawdown circuit breaker.
OVERRIDE_DRAWDOWN_HALT=false

# 2. Kalshi Configuration
# ------------------------
# Kalshi v2 API credentials.
KALSHI_USE_DEMO=true
KALSHI_API_URL=https://external-api.kalshi.com/trade-api/v2
KALSHI_DEMO_API_URL=https://external-api.demo.kalshi.co/trade-api/v2
KALSHI_API_KEY=your_kalshi_api_key_uuid_here
KALSHI_API_SECRET=your_kalshi_api_secret_base64_here
